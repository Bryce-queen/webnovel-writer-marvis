{
  "description": "Lightweight webnovel-writer runtime guardrails: short project status on session start and best-effort blocking for direct writes to Story System/read-model files.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"{SKILL_ROOT}/hooks/session_start.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "write_file",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"{SKILL_ROOT}/hooks/guard_runtime_write.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "shell_executor",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"{SKILL_ROOT}/hooks/guard_runtime_write.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
